{
  "manifest_version": 3,
  "name": "Job Hunter Tracker",
  "description": "Detects job application activity and stores application events locally in the browser.",
  "version": "1.1.1",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Hunter Tracker"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "dashboard.js", "dashboard-styles.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["ats-registry.js", "content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
